{
  "name": "Animepahe Smart Player",
  "version": "1.0",
  "description": "Adds 'Next Episode' shortcut (Shift+N) and 'Previous Episode' shortcut (Shift+Z) to AnimePahe.",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://*.animepahe.pw/play/*",
    "https://*.animepahe.si/play/*",
    "https://*.animepahe.com/play/*",
    "https://*.animepahe.pw/anime/*",
    "https://*.animepahe.si/anime/*",
    "https://*.animepahe.com/anime/*",
    "https://api.myanimelist.net/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://*.animepahe.pw/play/*",
        "https://*.animepahe.si/play/*",
        "https://*.animepahe.com/play/*",
        "https://*.animepahe.pw/anime/*",
        "https://*.animepahe.si/anime/*",
        "https://*.animepahe.com/anime/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/ext-icon.png",
      "24": "icons/ext-icon.png",
      "32": "icons/ext-icon.png"
    },
    "default_title": "Animepahe x Mal",
    "default_popup": "popup.html"
  },
  "manifest_version": 3
}
